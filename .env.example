# =============================================================================
# EXO SANCTRA — environment variables (copy to .env and fill in your values)
# =============================================================================

# --- Firebase (required — auth, Firestore, storage) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Stripe (required for checkout & webhooks) ---
STRIPE_CLIENT_SECRET=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SITE_URL=https://your-production-domain.com

# --- Wallet connect (Reown / WalletConnect) ---
NEXT_PUBLIC_REOWN_PROJECT_ID=
NEXT_PUBLIC_COMPANY_WALLET_ADDRESS=

# --- Outbound email (optional — required to send form notifications) ---
# Use your own Gmail + app password, or another SMTP provider.
SMTP_EMAIL_USER=
SMTP_EMAIL_PASSWORD=
SMTP_EMAIL_FROM=EXO SANCTRA <hello@yourdomain.com>
SMTP_EMAIL_SERVICE=gmail

# Default notification recipient when routes do not specify one
SMTP_NOTIFICATION_TO=hello@exosanctra.com

# --- Data export page (optional — password gate for /admin/data-export) ---
DATA_EXPORT_ACCESS_KEY=
